# Papalicious Backend — Environment Variables
# Set these in Vercel Dashboard → Project → Settings → Environment Variables

# ─── Database ───────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (get from https://cloud.mongodb.com)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/papalicious?retryWrites=true&w=majority

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 64
JWT_SECRET=your_strong_random_jwt_secret_here_min_32_chars
JWT_EXPIRE=7d

# ─── Cloudinary (Image Uploads) ───────────────────────────────────────────────
# Get from https://cloudinary.com → Dashboard
CLOUD_NAME=your_cloud_name
API_KEY=your_api_key
API_SECRET=your_api_secret

# ─── CORS — Frontend URLs ─────────────────────────────────────────────────────
# Set to your deployed Vercel frontend URLs AFTER deploying client & admin
CLIENT_URL=https://papalicious.vercel.app
ADMIN_URL=https://papalicious-admin.vercel.app

# ─── Email (Optional) ────────────────────────────────────────────────────────
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_from_google
